{
  "name": "viral-content-engine",
  "version": "1.0.2",
  "description": "One topic → 30+ ready-to-post viral images. Memes, quotes, hot takes, carousels. Free, local, no limits.",
  "keywords": [
    "viral",
    "social-media",
    "content",
    "memes",
    "ollama",
    "playwright",
    "tiktok",
    "instagram"
  ],
  "bin": {
    "viral": "./bin/viral.js"
  },
  "type": "module",
  "main": "dist/cli.js",
  "files": [
    "dist",
    "bin",
    "templates"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "prepublishOnly": "npm run build",
    "postinstall": "playwright install chromium 2>/dev/null || true"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "cosmiconfig": "^9.0.0",
    "execa": "^9.3.0",
    "handlebars": "^4.7.8",
    "ora": "^8.1.1",
    "playwright": "^1.49.1",
    "sharp": "^0.33.5",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "playwright": "^1.49.1",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SergiuPogor/viral-content-engine.git"
  },
  "author": "SergiuPogor"
}
